{
  "RecipeFormatVersion": "2020-01-25",
  "ComponentName": "com.fl.Worker",
  "ComponentVersion": "1.0.0",
  "ComponentPublisher": "Amazon",
  "ComponentConfiguration": {
    "DefaultConfiguration": {
      "accessControl": {
        "aws.greengrass.ipc.mqttproxy": {
          "com.fl.Worker:mqttproxy:1": {
            "operations": [
              "aws.greengrass#SubscribeToIoTCore"
            ],
            "resources": [
              "fl/1223683773/next-round"
            ]
          }
        }
      },
      "runWithDefault": {
        "posixUser": "cisco"
      }
    }
  },
  "Manifests": [
    {
      "Platform": {
        "os": "linux"
      },
      "Lifecycle": {
        "install": "python3 -c 'import awsiotsdk' || pip3 install awsiotsdk --break-system-packages",
        "run": "AWS_SHARED_CREDENTIALS_FILE=/home/cisco/.aws/credentials python3 -u {artifacts:path}/worker.py"
      }
    }
  ]
}